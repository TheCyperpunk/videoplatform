# ============================================
# Environment Variables Template
# Copy this file to .env and fill in values
# ============================================

# ── Backend Configuration ──────────────────
PORT=5002
NODE_ENV=production

# MongoDB Atlas Connection
# Get this from MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Frontend URL (for CORS)
# With Nginx: http://localhost (port 80)
# Without Nginx: http://localhost:3000
FRONTEND_URL=http://localhost

# ── Frontend Configuration ─────────────────
# API URL for frontend to connect to backend
# With Nginx: http://localhost/api
# Without Nginx: http://localhost:5002
NEXT_PUBLIC_API_URL=http://localhost/api

# ============================================
# Production Notes:
# ============================================
# 1. Never commit .env file to git
# 2. Use strong passwords for MongoDB
# 3. Update FRONTEND_URL to your domain in production
# 4. Update NEXT_PUBLIC_API_URL to your API domain
# 5. Consider using secrets management (AWS Secrets Manager, etc.)
# 6. Nginx is configured in docker-compose.yml and nginx.conf
# 7. For production with domain: use https://yourdomain.com
