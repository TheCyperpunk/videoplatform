# ============================================
# Kubernetes Secrets Template
# NEVER commit actual secrets to git!
# ============================================

apiVersion: v1
kind: Secret
metadata:
  name: videx-secrets
  namespace: videx
type: Opaque
stringData:
  # MongoDB Atlas connection string
  # Replace with your actual credentials
  mongodb-uri: "mongodb+srv://username:password@cluster.mongodb.net/videx?retryWrites=true&w=majority"

---
# How to create secrets from command line:
# kubectl create secret generic videx-secrets \
#   --from-literal=mongodb-uri='mongodb+srv://user:pass@cluster.mongodb.net/videx' \
#   --namespace=videx

# How to update secrets:
# kubectl delete secret videx-secrets --namespace=videx
# kubectl create secret generic videx-secrets \
#   --from-literal=mongodb-uri='mongodb+srv://user:pass@cluster.mongodb.net/videx' \
#   --namespace=videx

# How to view secrets:
# kubectl get secret videx-secrets --namespace=videx -o yaml
